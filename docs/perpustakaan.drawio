        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    KATEGORI {\n        int id_kategori PK\n        varchar kode_kategori UK\n        varchar nama_kategori\n        varchar deskripsi\n    }\n\n    PENERBIT {\n        int id_penerbit PK\n        varchar nama_penerbit\n        varchar kota\n        varchar email\n        varchar no_telepon\n    }\n\n    RAK {\n        int id_rak PK\n        varchar kode_rak UK\n        varchar nama_rak\n        int lantai\n        int kapasitas\n    }\n\n    ANGGOTA {\n        int id_anggota PK\n        varchar kode_anggota UK\n        varchar nama_lengkap\n        varchar email UK\n        varchar no_telepon\n        text alamat\n        date tanggal_daftar\n        enum status_anggota\n    }\n\n    PETUGAS {\n        int id_petugas PK\n        varchar kode_petugas UK\n        varchar nama_petugas\n        varchar username UK\n        varchar password_hash\n        varchar jabatan\n        varchar no_telepon\n    }\n\n    BUKU {\n        int id_buku PK\n        varchar isbn UK\n        varchar judul\n        varchar pengarang\n        int id_kategori FK\n        int id_penerbit FK\n        int id_rak FK\n        year tahun_terbit\n        varchar edisi\n        int jumlah_halaman\n        int stok_total\n        int stok_tersedia\n        varchar bahasa\n        text sinopsis\n    }\n\n    PEMINJAMAN {\n        int id_peminjaman PK\n        varchar kode_peminjaman UK\n        int id_anggota FK\n        int id_petugas FK\n        datetime tanggal_pinjam\n        date tanggal_batas_kembali\n        enum status_peminjaman\n        int total_buku\n    }\n\n    DETAIL_PEMINJAMAN {\n        int id_detail PK\n        int id_peminjaman FK\n        int id_buku FK\n        enum status_buku\n    }\n\n    PENGEMBALIAN {\n        int id_pengembalian PK\n        int id_peminjaman FK\n        int id_detail FK\n        int id_petugas FK\n        datetime tanggal_kembali\n        int terlambat_hari\n        decimal denda\n        enum kondisi_buku\n        text keterangan\n    }\n\n    RESERVASI {\n        int id_reservasi PK\n        int id_anggota FK\n        int id_buku FK\n        datetime tanggal_reservasi\n        date tanggal_kedaluwarsa\n        enum status_reservasi\n    }\n\n    DENDA {\n        int id PK\n        int id_pengembalian FK\n        int id_anggota FK\n        decimal total_denda\n        decimal sisa_denda\n        varchar status_denda\n        date tanggal_dikenakan\n        date tanggal_jatuh_tempo\n        text alasan_denda\n        int created_by FK\n        datetime created_at\n        datetime updated_at\n    }\n\n    PEMBAYARAN_DENDA {\n        int id PK\n        int id_denda FK\n        int id_petugas FK\n        decimal jumlah_bayar\n        datetime tanggal_bayar\n        varchar metode_bayar\n        varchar bukti_bayar\n        text keterangan\n        datetime created_at\n        datetime updated_at\n    }\n\n    RIWAYAT_STATUS_DENDA {\n        int id PK\n        int id_denda FK\n        varchar status_sebelum\n        varchar status_sesudah\n        int diubah_oleh FK\n        text alasan\n        datetime created_at\n        datetime updated_at\n    }\n\n    %% RELASI CROW&#39;S FOOT\n    KATEGORI ||--o{ BUKU : \&quot;\&quot;\n    PENERBIT ||--o{ BUKU : \&quot;\&quot;\n    RAK ||--o{ BUKU : \&quot;\&quot;\n\n    ANGGOTA ||--o{ PEMINJAMAN : \&quot;\&quot;\n    ANGGOTA ||--o{ RESERVASI : \&quot;\&quot;\n    ANGGOTA ||--o{ DENDA : \&quot;\&quot;\n\n    PETUGAS ||--o{ PEMINJAMAN : \&quot;\&quot;\n    PETUGAS ||--o{ PENGEMBALIAN : \&quot;\&quot;\n    PETUGAS ||--o{ DENDA : \&quot;\&quot;\n    PETUGAS ||--o{ PEMBAYARAN_DENDA : \&quot;\&quot;\n    PETUGAS ||--o{ RIWAYAT_STATUS_DENDA : \&quot;\&quot;\n\n    BUKU ||--o{ DETAIL_PEMINJAMAN : \&quot;\&quot;\n    BUKU ||--o{ RESERVASI : \&quot;\&quot;\n\n    PEMINJAMAN ||--o{ DETAIL_PEMINJAMAN : \&quot;\&quot;\n    PEMINJAMAN ||--o{ PENGEMBALIAN : \&quot;\&quot;\n\n    DETAIL_PEMINJAMAN ||--o| PENGEMBALIAN : \&quot;\&quot;\n    PENGEMBALIAN ||--o{ DENDA : \&quot;\&quot;\n\n    DENDA ||--o{ PEMBAYARAN_DENDA : \&quot;\&quot;\n    DENDA ||--o{ RIWAYAT_STATUS_DENDA : \&quot;\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="0HDnSIlidjYPk5POA6ZD-1">
